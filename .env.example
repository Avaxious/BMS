# Google Sheets IDs
DATA_SHEET_ID=1rct6063UB1M3gXuuU6NmTYqqnvurn6pQ
USERS_SHEET_ID=16m9UdjL2QQIC5l-Nivi4Zfp8RueRyBZ1
AUDIT_LOG_SHEET_ID=YOUR_AUDIT_LOG_SHEET_ID

# Security Settings
PASSWORD_HASH_ITERATIONS=100000
SESSION_TIMEOUT_MS=1800000
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_MS=300000

# Encryption Keys (Generated via crypto.getRandomValues)
ENCRYPTION_SALT=YOUR_BASE64_ENCODED_SALT
ENCRYPTION_IV=YOUR_BASE64_ENCODED_IV

# API Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=600000

# Allowed Origins (for CORS)
ALLOWED_ORIGINS=https://avaxious.github.io,https://yourdomain.com

# Logging
ENABLE_AUDIT_LOG=true
LOG_LEVEL=INFO
